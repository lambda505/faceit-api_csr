<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>FACEIT / <%= username %></title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  </head>
  <body>

    <h1>FACEIT / <%= username %></h1>

    <div class="meta">LEVEL: <%= profile.level %> &nbsp;|&nbsp; ELO: <%= profile.elo %></div>
    <div class="meta">COUNTRY: <%= profile.country.toUpperCase() %> &nbsp;|&nbsp; REGION: <%= profile.region %></div>
    <% if (profile.steamId) { %><div class="meta">STEAM: <a href="https://steamcommunity.com/profiles/<%= profile.steamId %>" target="_blank"><%= profile.steamId %></a></div><% } %>
    <% if (profile.faceitUrl) { %><div class="meta">FACEIT: <a href="<%= profile.faceitUrl %>" target="_blank"><%= profile.faceitUrl %></a></div><% } %>

    <h2>LIFETIME</h2>
    <table>
      <tr><td>Matches</td><td><%= stats['Matches'] %></td></tr>
      <tr><td>Wins</td><td><%= stats['Wins'] %></td></tr>
      <tr><td>Win Rate</td><td><%= stats['Win Rate %'] %>%</td></tr>
      <tr><td>Avg K/D Ratio</td><td><%= stats['Average K/D Ratio'] %></td></tr>
      <tr><td>Avg Headshots %</td><td><%= stats['Average Headshots %'] %>%</td></tr>
      <tr><td>Longest Win Streak</td><td><%= stats['Longest Win Streak'] %></td></tr>
      <tr><td>Current Win Streak</td><td><%= stats['Current Win Streak'] %></td></tr>
    </table>

    <h2>LIFETIME (COMPUTED FROM MAPS)</h2>
    <table>
      <tr><td>K/D Ratio</td><td><%= computed.kd %></td></tr>
      <tr><td>Headshots %</td><td><%= computed.hsPercent %>%</td></tr>
      <tr><td>Total Kills</td><td><%= computed.totalKills %></td></tr>
      <tr><td>Total Deaths</td><td><%= computed.totalDeaths %></td></tr>
      <tr><td>Total Assists</td><td><%= computed.totalAssists %></td></tr>
      <tr><td>Total Headshots</td><td><%= computed.totalHeadshots %></td></tr>
      <tr><td>Total MVPs</td><td><%= computed.totalMVPs %></td></tr>
      <tr><td>Total Triple Kills</td><td><%= computed.totalTriple %></td></tr>
      <tr><td>Total Quadro Kills</td><td><%= computed.totalQuadro %></td></tr>
      <tr><td>Total Penta Kills</td><td><%= computed.totalPenta %></td></tr>
      <tr><td>Avg Kills / Match</td><td><%= computed.avgKills %></td></tr>
      <tr><td>Avg Deaths / Match</td><td><%= computed.avgDeaths %></td></tr>
      <tr><td>Avg Assists / Match</td><td><%= computed.avgAssists %></td></tr>
    </table>

    <% if (history && history.length > 0) { %>
    <h2>RECENT RESULTS (LAST <%= history.length %> MATCHES)</h2>
    <div class="results-strip">
      <% history.slice().reverse().forEach(function(m) { %>
        <span class="result-dot <%= m.result === 1 ? 'win' : 'loss' %>"><%= m.result === 1 ? 'W' : 'L' %></span>
      <% }); %>
    </div>

    <% const eloHistory = history.filter(m => m.elo !== null); %>
    <% if (eloHistory.length > 1) { %>
    <h2>ELO PROGRESSION</h2>
    <div class="chart-wrap"><canvas id="chartElo"></canvas></div>
    <% } %>
    <% } %>

    <% if (segments && segments.length > 0) { %>
    <h2>MATCHES PLAYED PER MAP</h2>
    <div class="chart-wrap"><canvas id="chartMatches"></canvas></div>

    <h2>K/D RATIO PER MAP</h2>
    <div class="chart-wrap"><canvas id="chartKD"></canvas></div>

    <h2>WIN RATE PER MAP</h2>
    <div class="chart-wrap"><canvas id="chartWinRate"></canvas></div>

    <h2>AVG KILLS / DEATHS / ASSISTS PER MAP</h2>
    <div class="chart-wrap"><canvas id="chartKDA"></canvas></div>

    <h2>PER MAP — FULL STATS</h2>
    <% segments.forEach(function(seg) { %>
      <h2><%= seg.label %></h2>
      <table>
        <% Object.keys(seg.stats).forEach(function(key) { %>
          <tr><td><%= key %></td><td><%= seg.stats[key] %></td></tr>
        <% }); %>
      </table>
    <% }); %>
    <% } %>

    <a class="back" href="/">&lt; back</a>

    <script>
      const CHART_DEFAULTS = {
        font: { family: 'monospace', size: 11 },
        color: '#000',
      };
      Chart.defaults.font.family = 'monospace';
      Chart.defaults.font.size = 11;
      Chart.defaults.color = '#000';

      const segments = <%- JSON.stringify(segments) %>;
      const history  = <%- JSON.stringify(history) %>;

      const mapLabels   = segments.map(s => s.label);
      const mapMatches  = segments.map(s => parseInt(s.stats['Matches']) || 0);
      const mapKD       = segments.map(s => parseFloat(s.stats['Average K/D Ratio']) || 0);
      const mapWinRate  = segments.map(s => parseFloat(s.stats['Win Rate %']) || 0);
      const mapAvgKills = segments.map(s => parseFloat(s.stats['Average Kills']) || 0);
      const mapAvgDeaths= segments.map(s => parseFloat(s.stats['Average Deaths']) || 0);
      const mapAvgAssists=segments.map(s => parseFloat(s.stats['Average Assists']) || 0);

      const barOpts = (title) => ({
        indexAxis: 'y',
        responsive: true,
        plugins: {
          legend: { display: false },
          title: { display: false }
        },
        scales: {
          x: { grid: { color: '#eee' }, ticks: { font: { family: 'monospace', size: 11 } } },
          y: { grid: { display: false }, ticks: { font: { family: 'monospace', size: 11 } } }
        }
      });

      new Chart(document.getElementById('chartMatches'), {
        type: 'bar',
        data: { labels: mapLabels, datasets: [{ data: mapMatches, backgroundColor: '#000', borderWidth: 0 }] },
        options: barOpts()
      });

      new Chart(document.getElementById('chartKD'), {
        type: 'bar',
        data: { labels: mapLabels, datasets: [{ data: mapKD, backgroundColor: '#000', borderWidth: 0 }] },
        options: barOpts()
      });

      new Chart(document.getElementById('chartWinRate'), {
        type: 'bar',
        data: { labels: mapLabels, datasets: [{ data: mapWinRate, backgroundColor: '#000', borderWidth: 0 }] },
        options: { ...barOpts(), scales: { ...barOpts().scales, x: { ...barOpts().scales.x, max: 100 } } }
      });

      new Chart(document.getElementById('chartKDA'), {
        type: 'bar',
        data: {
          labels: mapLabels,
          datasets: [
            { label: 'Avg Kills',   data: mapAvgKills,   backgroundColor: '#000' },
            { label: 'Avg Deaths',  data: mapAvgDeaths,  backgroundColor: '#888' },
            { label: 'Avg Assists', data: mapAvgAssists, backgroundColor: '#ccc' }
          ]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          plugins: { legend: { position: 'bottom', labels: { font: { family: 'monospace', size: 11 }, boxWidth: 12 } } },
          scales: {
            x: { grid: { color: '#eee' }, ticks: { font: { family: 'monospace', size: 11 } } },
            y: { grid: { display: false }, ticks: { font: { family: 'monospace', size: 11 } } }
          }
        }
      });

      const eloHistory = history.filter(m => m.elo !== null);
      if (eloHistory.length > 1) {
        new Chart(document.getElementById('chartElo'), {
          type: 'line',
          data: {
            labels: eloHistory.map(m => m.date),
            datasets: [{
              data: eloHistory.map(m => m.elo),
              borderColor: '#000',
              borderWidth: 1.5,
              pointRadius: 2,
              pointBackgroundColor: '#000',
              backgroundColor: 'transparent',
              tension: 0.2
            }]
          },
          options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
              x: { grid: { color: '#eee' }, ticks: { font: { family: 'monospace', size: 10 }, maxTicksLimit: 10 } },
              y: { grid: { color: '#eee' }, ticks: { font: { family: 'monospace', size: 11 } } }
            }
          }
        });
      }
    </script>
  </body>
</html>
